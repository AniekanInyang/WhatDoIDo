# Copy this file to .env in the same folder.

GROQ_API_KEY=YOUR_GROQ_API_KEY
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY

# Optional but recommended for LangSmith tracing.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=whatdoido-local
